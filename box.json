{
    "output": ".build/skilltest.phar",
    "compression": "GZ",
    "finder": [
        {
            "in": "./",
            "exclude": [
                ".docker",
                "docs",
                "prd",
                "tests"
            ]
        }
    ],
    "blacklist": [
        ".dockerignore",
        ".editorconfig",
        ".gitattributes",
        ".github",
        ".gitignore",
        "CLAUDE.md",
        "box.json",
        "install.sh",
        "phpcs.xml",
        "phpstan.neon",
        "phpunit.xml",
        "rector.php",
        "renovate.json"
    ],
    "replacements": {
        "skilltest-version": "development"
    }
}
